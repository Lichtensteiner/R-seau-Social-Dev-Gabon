{
  "entities": {
    "Chat": {
      "title": "Chat",
      "description": "A 1-to-1 conversation between two users.",
      "type": "object",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of two user UIDs."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp of the last message."
        },
        "lastMessage": {
          "type": "string",
          "description": "Preview of the last message."
        }
      },
      "required": ["participants", "updatedAt"]
    },
    "Message": {
      "title": "Message",
      "description": "A single message in a chat.",
      "type": "object",
      "properties": {
        "senderId": {
          "type": "string",
          "description": "UID of the user who sent the message."
        },
        "text": {
          "type": "string",
          "description": "Text content of the message."
        },
        "createdAt": {
          "type": "string",
          "format": "date-time",
          "description": "Timestamp when the message was sent."
        },
        "read": {
          "type": "boolean",
          "description": "Whether the message has been read by the recipient."
        }
      },
      "required": ["senderId", "text", "createdAt", "read"]
    },
    "User": {
      "title": "User",
      "description": "A user profile in the developer network.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The user's unique ID." },
        "displayName": { "type": "string", "description": "The user's full name or display name." },
        "firstName": { "type": "string", "description": "The user's first name." },
        "lastName": { "type": "string", "description": "The user's last name." },
        "pseudo": { "type": "string", "description": "The user's username/pseudo." },
        "email": { "type": "string", "format": "email", "description": "The user's email address." },
        "photoURL": { "type": "string", "format": "uri", "description": "URL to the user's profile picture." },
        "bio": { "type": "string", "description": "A short biography." },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "List of technical skills." },
        "location": { "type": "string", "description": "City or region in Gabon." },
        "status": { "type": "string", "description": "Professional status (e.g., Étudiant, Junior, Senior)." },
        "experienceYears": { "type": "number", "description": "Years of experience." },
        "githubUrl": { "type": "string", "format": "uri", "description": "Link to GitHub profile." },
        "linkedInUrl": { "type": "string", "format": "uri", "description": "Link to LinkedIn profile." },
        "portfolioUrl": { "type": "string", "format": "uri", "description": "Link to personal portfolio." },
        "role": { "type": "string", "enum": ["dev", "recruiter", "writer", "admin"], "description": "User role." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Account creation timestamp." },
        "lastLoginAt": { "type": "string", "format": "date-time", "description": "Last login timestamp." },
        "followers": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs following this user." },
        "following": { "type": "array", "items": { "type": "string" }, "description": "List of UIDs this user is following." },
        "theme": { "type": "string", "enum": ["light", "dark"], "description": "User's preferred theme." }
      },
      "required": ["uid", "displayName", "email", "role", "createdAt"]
    },
    "Post": {
      "title": "Post",
      "description": "A social feed post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string", "description": "UID of the author." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "authorPhoto": { "type": "string", "description": "Photo URL of the author." },
        "content": { "type": "string", "description": "Text content of the post." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "likesCount": { "type": "number", "description": "Number of likes." },
        "commentsCount": { "type": "number", "description": "Number of comments." }
      },
      "required": ["authorId", "authorName", "content", "createdAt", "likesCount", "commentsCount"]
    },
    "Job": {
      "title": "Job",
      "description": "A job or mission opportunity.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string", "description": "UID of the recruiter/author." },
        "companyName": { "type": "string", "description": "Name of the company." },
        "title": { "type": "string", "description": "Job title." },
        "type": { "type": "string", "enum": ["CDI", "CDD", "Stage", "Freelance"], "description": "Contract type." },
        "location": { "type": "string", "description": "Job location." },
        "description": { "type": "string", "description": "Detailed job description." },
        "skills": { "type": "array", "items": { "type": "string" }, "description": "Required skills." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["authorId", "companyName", "title", "type", "location", "description", "createdAt"]
    },
    "Article": {
      "title": "Article",
      "description": "A long-form article or blog post.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string", "description": "UID of the author." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "title": { "type": "string", "description": "Title of the article." },
        "content": { "type": "string", "description": "Markdown content of the article." },
        "summary": { "type": "string", "description": "Short summary of the article." },
        "coverImage": { "type": "string", "format": "uri", "description": "URL to the cover image." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "List of tags." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." },
        "likesCount": { "type": "number", "description": "Number of likes." },
        "viewsCount": { "type": "number", "description": "Number of views." }
      },
      "required": ["authorId", "authorName", "title", "content", "createdAt"]
    },
    "Book": {
      "title": "Book",
      "description": "A book published or showcased by a user.",
      "type": "object",
      "properties": {
        "authorId": { "type": "string", "description": "UID of the author." },
        "authorName": { "type": "string", "description": "Display name of the author." },
        "title": { "type": "string", "description": "Title of the book." },
        "description": { "type": "string", "description": "Description or synopsis of the book." },
        "coverImage": { "type": "string", "format": "uri", "description": "URL to the book cover." },
        "purchaseUrl": { "type": "string", "format": "uri", "description": "Link to buy the book." },
        "genre": { "type": "string", "description": "Genre of the book." },
        "publishedDate": { "type": "string", "format": "date", "description": "Date of publication." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Timestamp when added to the platform." }
      },
      "required": ["authorId", "authorName", "title", "description", "createdAt"]
    },
    "Activity": {
      "title": "Activity",
      "description": "A log of user activity in the system.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user." },
        "userName": { "type": "string", "description": "Name of the user." },
        "type": { "type": "string", "description": "Type of activity (e.g., login, post_create)." },
        "details": { "type": "string", "description": "Additional details about the activity." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the activity occurred." }
      },
      "required": ["userId", "type", "timestamp"]
    },
    "LeaderboardEntry": {
      "title": "LeaderboardEntry",
      "description": "A user's standing in the elite ranking.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user." },
        "displayName": { "type": "string", "description": "Name of the user." },
        "photoURL": { "type": "string", "description": "Photo URL of the user." },
        "points": { "type": "number", "description": "Total points accumulated." },
        "rank": { "type": "number", "description": "Current rank." },
        "badges": { "type": "array", "items": { "type": "string" }, "description": "List of earned prestige badges." },
        "updatedAt": { "type": "string", "format": "date-time", "description": "Last update timestamp." }
      },
      "required": ["userId", "points", "updatedAt"]
    },
    "Challenge": {
      "title": "Challenge",
      "description": "A coding challenge in the Battleground.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Title of the challenge." },
        "description": { "type": "string", "description": "Detailed description." },
        "difficulty": { "type": "string", "enum": ["Easy", "Medium", "Hard", "Elite"], "description": "Difficulty level." },
        "points": { "type": "number", "description": "Points awarded for completion." },
        "type": { "type": "string", "enum": ["Flash", "Duel", "Hackathon"], "description": "Type of challenge." },
        "status": { "type": "string", "enum": ["Active", "Closed", "Upcoming"], "description": "Current status." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["title", "description", "difficulty", "points", "type", "status", "createdAt"]
    },
    "ChallengeSubmission": {
      "title": "ChallengeSubmission",
      "description": "A user's submission for a challenge.",
      "type": "object",
      "properties": {
        "challengeId": { "type": "string", "description": "ID of the challenge." },
        "userId": { "type": "string", "description": "UID of the user." },
        "code": { "type": "string", "description": "Submitted code or link." },
        "status": { "type": "string", "enum": ["Pending", "Accepted", "Rejected"], "description": "Submission status." },
        "score": { "type": "number", "description": "Score awarded." },
        "submittedAt": { "type": "string", "format": "date-time", "description": "Submission timestamp." }
      },
      "required": ["challengeId", "userId", "code", "status", "submittedAt"]
    },
    "ImpactProject": {
      "title": "ImpactProject",
      "description": "A project with real impact in Gabon.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Project title." },
        "description": { "type": "string", "description": "Project description." },
        "authorId": { "type": "string", "description": "UID of the creator." },
        "impactScore": { "type": "number", "description": "Calculated impact index." },
        "status": { "type": "string", "enum": ["Draft", "Published", "Featured"], "description": "Publication status." },
        "tags": { "type": "array", "items": { "type": "string" }, "description": "Relevant tags." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["title", "description", "authorId", "impactScore", "status", "createdAt"]
    },
    "Mentorship": {
      "title": "Mentorship",
      "description": "A mentorship relationship.",
      "type": "object",
      "properties": {
        "mentorId": { "type": "string", "description": "UID of the mentor." },
        "menteeId": { "type": "string", "description": "UID of the mentee." },
        "status": { "type": "string", "enum": ["Pending", "Active", "Completed", "Cancelled"], "description": "Relationship status." },
        "startDate": { "type": "string", "format": "date-time", "description": "When it started." },
        "endDate": { "type": "string", "format": "date-time", "description": "When it ended." }
      },
      "required": ["mentorId", "menteeId", "status", "startDate"]
    },
    "Certification": {
      "title": "Certification",
      "description": "An internal certification earned by a user.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user." },
        "title": { "type": "string", "description": "Title of the certification." },
        "issuerId": { "type": "string", "description": "UID of the issuer (usually an admin or mentor)." },
        "date": { "type": "string", "format": "date-time", "description": "Date issued." }
      },
      "required": ["userId", "title", "issuerId", "date"]
    },
    "TechnicalTest": {
      "title": "TechnicalTest",
      "description": "A technical test for Commando Recruitment.",
      "type": "object",
      "properties": {
        "title": { "type": "string", "description": "Test title." },
        "description": { "type": "string", "description": "Test description." },
        "duration": { "type": "number", "description": "Duration in minutes." },
        "difficulty": { "type": "string", "enum": ["Junior", "Intermediate", "Senior", "Expert"], "description": "Difficulty level." },
        "questions": { "type": "array", "items": { "type": "object" }, "description": "List of questions." },
        "createdAt": { "type": "string", "format": "date-time", "description": "Creation timestamp." }
      },
      "required": ["title", "description", "duration", "difficulty", "createdAt"]
    },
    "TestResult": {
      "title": "TestResult",
      "description": "Result of a technical test.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "UID of the user." },
        "testId": { "type": "string", "description": "ID of the test." },
        "score": { "type": "number", "description": "Score achieved." },
        "status": { "type": "string", "enum": ["Passed", "Failed", "In-Progress"], "description": "Result status." },
        "completedAt": { "type": "string", "format": "date-time", "description": "Completion timestamp." }
      },
      "required": ["userId", "testId", "score", "status", "completedAt"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Collection of user profiles."
    },
    "/posts/{postId}": {
      "schema": { "$ref": "#/entities/Post" },
      "description": "Collection of feed posts."
    },
    "/jobs/{jobId}": {
      "schema": { "$ref": "#/entities/Job" },
      "description": "Collection of job opportunities."
    },
    "/chats/{chatId}": {
      "schema": { "$ref": "#/entities/Chat" },
      "description": "1-to-1 conversations between users."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": { "$ref": "#/entities/Message" },
      "description": "Messages within a specific chat."
    },
    "/articles/{articleId}": {
      "schema": { "$ref": "#/entities/Article" },
      "description": "Collection of long-form articles."
    },
    "/books/{bookId}": {
      "schema": { "$ref": "#/entities/Book" },
      "description": "Collection of books."
    },
    "/activities/{activityId}": {
      "schema": { "$ref": "#/entities/Activity" },
      "description": "Collection of system activities."
    },
    "/leaderboard/{userId}": {
      "schema": { "$ref": "#/entities/LeaderboardEntry" },
      "description": "Elite ranking leaderboard."
    },
    "/challenges/{challengeId}": {
      "schema": { "$ref": "#/entities/Challenge" },
      "description": "Battleground coding challenges."
    },
    "/challenges/{challengeId}/submissions/{submissionId}": {
      "schema": { "$ref": "#/entities/ChallengeSubmission" },
      "description": "Submissions for challenges."
    },
    "/impact_projects/{projectId}": {
      "schema": { "$ref": "#/entities/ImpactProject" },
      "description": "Projects with real impact in Gabon."
    },
    "/mentorships/{mentorshipId}": {
      "schema": { "$ref": "#/entities/Mentorship" },
      "description": "Mentorship relationships."
    },
    "/certifications/{certId}": {
      "schema": { "$ref": "#/entities/Certification" },
      "description": "Internal certifications."
    },
    "/technical_tests/{testId}": {
      "schema": { "$ref": "#/entities/TechnicalTest" },
      "description": "Commando recruitment tests."
    },
    "/test_results/{resultId}": {
      "schema": { "$ref": "#/entities/TestResult" },
      "description": "Results of technical tests."
    }
  }
}
